{
  "name": "mission-learning-sandbox",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace @mission/server\" \"npm run dev --workspace @mission/web\"",
    "dev:web": "npm run dev --workspace @mission/web",
    "dev:server": "npm run dev --workspace @mission/server",
    "build": "npm run build --workspace @mission/web && npm run build --workspace @mission/server",
    "start": "node scripts/start-production.mjs",
    "tiles:sample": "powershell.exe -ExecutionPolicy Bypass -File scripts/generate-sample-tiles.ps1",
    "tiles:download": "node scripts/download-sample-tiles.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
